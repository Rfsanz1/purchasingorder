modules = ["nodejs-20", "php-8.2", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["bash", "start-production.sh"]
build = ["bash", "-c", "composer install --no-dev --optimize-autoloader --no-interaction"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "POS App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Modern Backend (NestJS)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Modern Frontend (Next.js)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 bash start.sh"
waitForPort = 5000

[[workflows.workflow]]
name = "POS App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend/artifacts/pos-app && pnpm dev"
waitForPort = 5173

[[workflows.workflow]]
name = "Modern Backend (NestJS)"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/backend && PORT=6000 pnpm start:dev"
waitForPort = 6000

[[workflows.workflow]]
name = "Modern Frontend (Next.js)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/frontend && NEXT_PUBLIC_API_URL=http://localhost:6000/api pnpm dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_database:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 6000

[[ports]]
localPort = 3306
externalPort = 6800

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 5174
externalPort = 3002

[[ports]]
localPort = 6000
externalPort = 6000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 5173

[[ports]]
localPort = 23287
externalPort = 3000

[[ports]]
localPort = 23288
externalPort = 5000

[[ports]]
localPort = 23289
externalPort = 4200

[[ports]]
localPort = 23636
externalPort = 8000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_NAME = "Gentong Mas ERP"
APP_LOCALE = "id"
APP_FALLBACK_LOCALE = "id"
DB_CONNECTION = "pgsql"
DB_HOST = "helium"
DB_PORT = "5432"
DB_DATABASE = "heliumdb"
DB_USERNAME = "postgres"
DB_SSLMODE = "disable"
SESSION_DRIVER = "file"
CACHE_STORE = "file"
QUEUE_CONNECTION = "sync"
SESSION_SAME_SITE = "none"
SESSION_SECURE_COOKIE = "true"
APP_KEY = "base64:77bISlISnpVyiKgTWeA+WYUcrOa0KZSySnHqiVg+B3A="

[userenv.development]
APP_ENV = "local"
APP_DEBUG = "true"

[userenv.production]
APP_ENV = "production"
APP_DEBUG = "false"
LOG_CHANNEL = "stderr"
LOG_LEVEL = "error"
