APP_NAME="Gentong Mas ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ══════════════════════════════════════════════════════════════════
# DATABASE — Pilih salah satu metode:
# ══════════════════════════════════════════════════════════════════
#
# METODE 1: URL lengkap (direkomendasikan untuk Railway, Render, Replit)
#
#   PostgreSQL:  DATABASE_URL=postgresql://user:password@host:5432/dbname
#   MySQL:       MYSQL_URL=mysql://user:password@host:3306/dbname
#
# METODE 2: Variabel terpisah (untuk InfinityFree, cPanel, Hostinger)
#
#   DB_CONNECTION=mysql
#   DB_HOST=127.0.0.1
#   DB_PORT=3306
#   DB_DATABASE=gentongmas
#   DB_USERNAME=root
#   DB_PASSWORD=secret
#
# start.sh dan start-production.sh akan otomatis mendeteksi mana yang dipakai.
# Prioritas: MYSQL_URL > DATABASE_URL > DB_* variabel manual
# ══════════════════════════════════════════════════════════════════

# --- PostgreSQL (Replit Native DB / Railway / Render) ---
DATABASE_URL=

# --- MySQL (InfinityFree / cPanel / Hostinger / Koyeb) ---
MYSQL_URL=

# --- Fallback manual (jika tidak pakai URL) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=postgres
DB_PASSWORD=

# ══════════════════════════════════════════════════════════════════
# SESSION & CACHE
# ══════════════════════════════════════════════════════════════════
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=none
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ══════════════════════════════════════════════════════════════════
# MAIL (log saja untuk dev)
# ══════════════════════════════════════════════════════════════════
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@gentongmas.com"
MAIL_FROM_NAME="${APP_NAME}"

# ══════════════════════════════════════════════════════════════════
# INTEGRASI WHATSAPP — Fonnte
# Daftar: https://fonnte.com
# ══════════════════════════════════════════════════════════════════
FONNTE_TOKEN=your_fonnte_token_here
FONNTE_TOKEN_GROUP=
FONNTE_TOKEN_CUSTOMER=

# ID grup WhatsApp untuk notifikasi (format: 12036xxx@g.us)
FONNTE_GROUP_INVOICE=
FONNTE_GROUP_BUKTI_TF=

# ══════════════════════════════════════════════════════════════════
# INTEGRASI KLEDO ERP
# Daftar & ambil token: https://kledo.com → Pengaturan → API
#
# KLEDO = DATABASE UTAMA. ERP ini hanya interface/perantara.
# Semua transaksi, pelanggan, invoice disimpan di Kledo.
# ERP hanya: sinkronisasi, tampilkan data, buat transaksi, laporan.
# ══════════════════════════════════════════════════════════════════
KLEDO_TOKEN=your_kledo_personal_access_token_here

# ══════════════════════════════════════════════════════════════════
# AUTENTIKASI ADMIN
# ══════════════════════════════════════════════════════════════════
ADMIN_PASSWORD=admin123

# ══════════════════════════════════════════════════════════════════
# PRODUKSI (opsional)
# ══════════════════════════════════════════════════════════════════
# PUBLIC_APP_URL=https://erp.gentongmas.com
