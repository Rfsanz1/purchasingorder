APP_NAME="Purchase Order"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────────────────────
# Pilih salah satu:
# 1. MySQL (Render, Koyeb, InfinityFree, dsb) → set MYSQL_URL
# 2. PostgreSQL (Replit native DB) → set DATABASE_URL
#
# Format MySQL:  mysql://user:password@host:3306/dbname
# Format PgSQL:  postgresql://user:password@host:5432/dbname
#
# start.sh dan start-production.sh akan otomatis deteksi mana yang dipakai.

MYSQL_URL=
DATABASE_URL=

# Fallback manual (jika tidak pakai URL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gentongmas
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@gentongmas.com"
MAIL_FROM_NAME="${APP_NAME}"

# Fonnte WhatsApp
FONNTE_TOKEN=
FONNTE_TOKEN_GROUP=
FONNTE_TOKEN_CUSTOMER=
FONNTE_GROUP_INVOICE=
FONNTE_GROUP_BUKTI_TF=

# Kledo ERP
KLEDO_TOKEN=

# Admin password (default: admin123)
ADMIN_PASSWORD=admin123
